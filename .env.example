# ══════════════════════════════════════════════════════════════════════════════
# Vitfix.io — Variables d'environnement (modèle)
# ══════════════════════════════════════════════════════════════════════════════
# Usage : dev local + reprise après sinistre uniquement.
#   cp .env.example .env.local   puis remplir les valeurs.
#
# ⚠️ PRODUCTION : les secrets passent EXCLUSIVEMENT par `wrangler secret put`
#    (Cloudflare Workers). Jamais de fichier .env en clair en prod.
#
# Source de vérité du classement requis/optionnel : lib/env.ts (validateEnv).
#   [REQUIS]    — validateEnv() throw en dev si absente.
#   [OPTIONNEL] — absence = fonctionnalité désactivée ou valeur par défaut.
#   [BUILD]     — utile au build/CI uniquement, pas au runtime prod.
# Toutes les valeurs ci-dessous sont des placeholders — jamais de vraie clé ici.
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# [REQUIS] URL du projet Supabase. Dashboard Supabase > Settings > API.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# [REQUIS] Clé anonyme (publique, safe côté navigateur). Même page Settings > API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
# [REQUIS] Clé service role — bypass RLS, JAMAIS exposée côté client. Settings > API.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── URLs application ──────────────────────────────────────────────────────────
# [OPTIONNEL] URL publique de l'app (sitemaps, robots, invitations équipe, referer OpenRouter). Défaut : https://vitfix.io
NEXT_PUBLIC_APP_URL=http://localhost:3000
# [OPTIONNEL] URL du site pour liens emails RFQ + auto-appel du poll Gmail par le webhook. Défaut : https://vitfix.io
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# [OPTIONNEL] Base API pour l'app mobile Capacitor (app/pro/mobile). Vide = même origine.
NEXT_PUBLIC_API_URL=

# ── Stripe (paiements / abonnements) ──────────────────────────────────────────
# [OPTIONNEL] Clé secrète Stripe — getStripe() (lib/stripe.ts) throw à l'usage si absente. Dashboard Stripe > Developers > API keys.
STRIPE_SECRET_KEY=sk_live_...
# [OPTIONNEL] Secret de signature des webhooks Stripe (app/api/stripe/webhook). Dashboard Stripe > Webhooks.
STRIPE_WEBHOOK_SECRET=whsec_...
# [OPTIONNEL] Clé publique Stripe — listée dans lib/env.ts mais non lue ailleurs dans le code à ce jour.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# [OPTIONNEL] Price ID du plan Artisan Pro (lib/stripe.ts PLANS). Dashboard Stripe > Products.
STRIPE_PRICE_ARTISAN_PRO=price_...
# [OPTIONNEL] Price ID du plan Syndic Essentiel (lib/stripe.ts PLANS).
STRIPE_PRICE_SYNDIC_ESSENTIAL=price_...
# [OPTIONNEL] Price ID du plan Syndic Premium (lib/stripe.ts PLANS).
STRIPE_PRICE_SYNDIC_PREMIUM=price_...

# ── IA (Groq, Cerebras, OpenRouter, Tavily) ───────────────────────────────────
# [OPTIONNEL] Clé Groq (Llama 3.3 70B) — provider principal des 10 agents IA (Fixy, Léa, Max…). console.groq.com.
GROQ_API_KEY=gsk_...
# [OPTIONNEL] Clé Cerebras — provider de secours quand Groq atteint son rate-limit (lib/cerebras.ts ; Max Syndic, analyse devis). cloud.cerebras.ai.
CEREBRAS_API_KEY=csk-...
# [OPTIONNEL] Clé OpenRouter — fallback LLM de l'agent Matériaux AI (app/api/materiaux-ai). openrouter.ai/keys.
OPENROUTER_API_KEY=sk-or-...
# [OPTIONNEL] Clé Tavily — recherche web produits de l'agent Matériaux AI. app.tavily.com.
TAVILY_API_KEY=tvly-...

# ── Email / Resend ────────────────────────────────────────────────────────────
# [OPTIONNEL] Clé Resend pour l'envoi d'emails transactionnels (lib/email.ts, contact, KYC). resend.com/api-keys.
RESEND_API_KEY=re_...
# [OPTIONNEL] Adresse From par défaut. Défaut : VITFIX <noreply@...> (lib/email.ts).
RESEND_FROM_EMAIL=VITFIX <noreply@vitfix.io>
# [OPTIONNEL] Secret de signature des webhooks Resend (app/api/webhooks/resend). Dashboard Resend > Webhooks.
RESEND_WEBHOOK_SECRET=whsec_...

# ── Gmail / Alfredo (agent email syndic) ──────────────────────────────────────
# [OPTIONNEL] OAuth Google — requis seulement si l'agent email Gmail est activé (connect/callback + refresh lib/auth-helpers.ts). console.cloud.google.com > Credentials.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
# [OPTIONNEL] Token attendu dans le header x-gmail-webhook-token du push Pub/Sub (app/api/email-agent/webhook répond 401 si absent). Valeur libre, à reporter dans l'URL d'abonnement Pub/Sub.
GMAIL_WEBHOOK_SECRET=valeur-aleatoire-longue
# [OPTIONNEL] Token du déclenchement interne webhook→poll (header x-internal-trigger, comparaison à temps constant côté /api/email-agent/poll). Sans lui, le poll temps réel Alfredo est désactivé (warn explicite). Générer : openssl rand -hex 32.
INTERNAL_POLL_TOKEN=valeur-aleatoire-longue
# [OPTIONNEL] Projet GCP hébergeant le topic Pub/Sub — utilisé par scripts/renew-gmail-watches.ts uniquement.
GCP_PROJECT_ID=mon-projet-gcp
# [OPTIONNEL] Nom du topic Pub/Sub Gmail watch — utilisé par scripts/renew-gmail-watches.ts uniquement.
GMAIL_PUSH_TOPIC=gmail-push

# ── Langfuse (observabilité IA) ───────────────────────────────────────────────
# [OPTIONNEL] Tracing désactivé si les 2 clés ne sont pas présentes (lib/langfuse.ts). cloud.langfuse.com > Settings.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
# [OPTIONNEL] Host Langfuse. Défaut : https://cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com
# [OPTIONNEL] Sel de hachage PII des traces. Défaut : LANGFUSE_PUBLIC_KEY.
LANGFUSE_PII_SALT=sel-aleatoire

# ── Sentry (monitoring erreurs) ───────────────────────────────────────────────
# [OPTIONNEL] DSN Sentry (client + serveur + edge). sentry.io > Project Settings > Client Keys.
NEXT_PUBLIC_SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx
# [BUILD] Token d'upload des source maps au build CI uniquement (lib/env.ts buildOnlyVars). Inutile au runtime.
SENTRY_AUTH_TOKEN=sntrys_...

# ── Upstash Redis (rate limiting distribué + cache) ───────────────────────────
# [OPTIONNEL] Sans ces 2 vars, le rate limiting retombe en mémoire locale (lib/cache.ts). console.upstash.com.
UPSTASH_REDIS_REST_URL=https://xxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=AXxx...

# ── Fiscal Portugal (AT / SAF-T) ──────────────────────────────────────────────
# [OPTIONNEL] Numéro de certification AT (lib/portugal-fiscal.ts). Défaut placeholder : 0000/AT.
PT_FISCAL_CERT_NUMBER=1234/AT
# [OPTIONNEL] Clé privée RSA PEM pour la signature des documents fiscaux PT (hash chain Portaria 363/2010).
PT_FISCAL_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ── Comptes admin ─────────────────────────────────────────────────────────────
# [OPTIONNEL] Email du super_admin — autorise l'accès aux routes /api/admin/* et le setup initial.
ADMIN_EMAIL=admin@exemple.com
# [OPTIONNEL] Mot de passe utilisé par /api/admin/setup pour créer le compte admin.
ADMIN_PASSWORD=mot-de-passe-fort
# [OPTIONNEL] Second compte admin (même usage).
ADMIN_EMAIL_2=admin2@exemple.com
ADMIN_PASSWORD_2=mot-de-passe-fort

# ── Sécurité interne ──────────────────────────────────────────────────────────
# [OPTIONNEL] Secret des cron jobs (header x-cron-key : poll Gmail, scan tenders, Léa documents…). Valeur libre longue.
CRON_SECRET=valeur-aleatoire-longue
# [OPTIONNEL] Secret des appels API internes (header x-internal-secret : KYC, run-automations, ingest corpus PT).
INTERNAL_API_SECRET=valeur-aleatoire-longue
# [OPTIONNEL] Secret HMAC du chaînage cryptographique des documents émis (lib/document-integrity.ts) — throw à la 1re émission de devis/facture si absent ou < 32 chars.
DOC_HASH_SECRET=chaine-aleatoire-de-32-caracteres-minimum
# [OPTIONNEL] Clé AES de chiffrement des tokens OAuth Gmail (lib/oauth/tokens.ts) — throw à l'usage si absente ou < 32 chars. Requise si Alfredo est activé.
OAUTH_TOKENS_ENCRYPTION_KEY=chaine-aleatoire-de-32-caracteres-minimum
# [OPTIONNEL] Secret HMAC du webhook de réception e-facture FR via Plateforme Agréée (app/api/pa-incoming, stub — endpoint répond 503 si absent).
PA_INBOUND_SECRET=valeur-aleatoire-longue

# ── Outillage / tests — optionnel, jamais nécessaire au runtime ───────────────
# Flags de scripts, seeds et E2E. À définir ponctuellement en ligne de commande,
# pas dans .env.local. (CI est posée automatiquement par GitHub Actions.)
# BASE_URL=http://127.0.0.1:3000          # Base des E2E Playwright (playwright.config.ts)
# SIMULATEUR_E2E_URL=                     # URL cible du spec e2e/simulateur-v2
# SIMULATEUR_E2E_SKIP=true                # Skip du spec simulateur-v2
# RUN_LEA_DOCS_E2E=1                      # Active e2e/syndic-lea-documents
# RUN_AGENTS_IA_E2E=1                     # Active e2e/syndic-agents-ia
# SEED_EMAIL= / SEED_PASSWORD=            # scripts/seed-artisan, seed-demo-*
# SEED_CLIENT_EMAIL= / SEED_CLIENT_PASSWORD=  # scripts/seed-client
# TARGET_USER_ID=                         # scripts/seed-agents-ia-demo-pt
# SKIP_LEA=1                              # scripts/seed-agents-ia-demo-pt (saute Léa)
# ANALYZE=true                            # Bundle analyzer au build (next.config.ts)
# MOBILE_BUILD=true                       # Build Capacitor (app/layout.tsx) — posé par npm run mobile:build
# FONT_DIR=/tmp/og-fonts                  # scripts/gen-og-image.mjs
