{
  "name": "fixit-production",
  "version": "0.6.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint --max-warnings=959",
    "mobile:build": "bash scripts/build-mobile.sh both",
    "mobile:ios": "bash scripts/build-mobile.sh ios",
    "mobile:android": "bash scripts/build-mobile.sh android",
    "mobile:sync": "npx cap sync",
    "mobile:open:ios": "npx cap open ios",
    "mobile:open:android": "npx cap open android",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "scan:secrets": "gitleaks detect --source . --config security/.gitleaks.toml --report-path security/outputs/gitleaks.json --report-format json",
    "scan:deps": "trivy fs . --severity HIGH,CRITICAL --ignorefile security/.trivyignore --format json --output security/outputs/trivy.json",
    "scan:code": "semgrep scan --config security/.semgrep.yml --json --output security/outputs/semgrep.json",
    "scan:web": "nuclei -u https://vitfix.io -config security/nuclei-config.yml -o security/outputs/nuclei.txt",
    "scan:all": "npm run scan:secrets && npm run scan:deps && npm run scan:code",
    "scan:lighthouse": "lhci autorun",
    "analyze": "ANALYZE=true next build",
    "build:cloudflare": "npx @opennextjs/cloudflare build",
    "seed:legal-corpus": "tsx scripts/seed-max-legal-corpus.ts",
    "prepare": "husky || true"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@capacitor/haptics": "^8.0.0",
    "@capacitor/ios": "^8.1.0",
    "@capacitor/local-notifications": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@sentry/nextjs": "^10.56.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.95.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.3.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "langfuse": "^3.38.20",
    "lucide-react": "^0.563.0",
    "next": "^16.2.9",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "5.4.296",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.11.0",
    "sonner": "^2.0.7",
    "stripe": "^20.4.0",
    "swr": "^2.4.1",
    "tailwind-merge": "^3.4.0",
    "unpdf": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.3",
    "@opennextjs/cloudflare": "^1.19.11",
    "@opentelemetry/instrumentation-lru-memoizer": "^0.57.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9",
    "eslint-config-next": "^16.2.2",
    "exceljs": "^4.4.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "pg": "^8.18.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  },
  "overrides": {
    "uuid": "^14.0.0"
  }
}
